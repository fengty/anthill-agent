# Anthill — example environment for docker-compose or local export.
# Copy to .env and fill in the keys you actually use. Everything is optional
# except at least one model key.

# --- Models (pick at least one) ---
# ANTHILL_DEEPSEEK_KEY=sk-...
# ANTHILL_MINIMAX_KEY=...
# ANTHILL_MINIMAX_GROUP=...

# --- Search providers (optional, web_search needs ONE of these) ---
# BOCHA_API_KEY=sk-...          # bochaai.com, recommended in China
# TAVILY_API_KEY=tvly-...       # tavily.com, recommended internationally
# SERPER_API_KEY=...            # serper.dev, Google results
# BRAVE_API_KEY=...             # Brave Search

# --- Daemon (anthill serve) ---
# ANTHILL_DAEMON_NATION=default
# ANTHILL_DAEMON_HOST=0.0.0.0
# ANTHILL_DAEMON_PORT=8765

# --- Lark / Feishu ---
# ANTHILL_LARK_APP_ID=cli_...
# ANTHILL_LARK_APP_SECRET=...
# ANTHILL_LARK_VERIFICATION_TOKEN=...

# --- Telegram ---
# ANTHILL_TELEGRAM_BOT_TOKEN=...

# --- Slack ---
# ANTHILL_SLACK_BOT_TOKEN=xoxb-...

# --- WeCom / 企业微信 ---
# ANTHILL_WECOM_CORP_ID=...
# ANTHILL_WECOM_CORP_SECRET=...
# ANTHILL_WECOM_AGENT_ID=1000002

# --- Optional features ---
# ANTHILL_USE_JUDGE=1                       # enable LLM judge scoring
# ANTHILL_PLUGIN_SHELL_ENABLED=1            # enable shell plugin (caution)
# ANTHILL_PLUGIN_CODE_EXEC_ENABLED=1        # enable code_exec plugin (caution)
# ANTHILL_PLUGIN_WORKSPACE=/home/anthill/workspace
