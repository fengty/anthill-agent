# Anthill — env-var FALLBACK for Docker Compose, CI, and scripted bring-up.
#
# The recommended way to configure Anthill is the CLI:
#
#   anthill model add deepseek --provider deepseek --model deepseek-chat \
#     --key sk-... --set-default
#   anthill channel add larkbot --kind lark --app-id cli_... --app-secret ...
#
# That writes to ~/.anthill/secrets.toml (chmod 600, .gitignored), survives
# across restarts, and lets `anthill model list` / `anthill channel show`
# inspect what's configured.
#
# This file exists so docker-compose and CI runners can still seed config
# from the environment without anyone having to exec into a container.
# Every Anthill provider/channel reads its CLI config FIRST, then falls
# back to these env vars only when nothing is configured. For normal
# local use you should not need this file at all.

# --- Models (one of these is enough; CLI: anthill model add) ---
# ANTHILL_DEEPSEEK_KEY=sk-...
# ANTHILL_MINIMAX_KEY=...
# ANTHILL_MINIMAX_GROUP=...

# --- Search providers (web_search needs ONE; no CLI yet — env only) ---
# BOCHA_API_KEY=sk-...          # bochaai.com, recommended in China
# TAVILY_API_KEY=tvly-...       # tavily.com, recommended internationally
# SERPER_API_KEY=...            # serper.dev, Google results
# BRAVE_API_KEY=...             # Brave Search

# --- Daemon (anthill serve) — usually CLI flags --host/--port are enough ---
# ANTHILL_DAEMON_NATION=default
# ANTHILL_DAEMON_HOST=0.0.0.0
# ANTHILL_DAEMON_PORT=8765

# --- Lark / Feishu (CLI: anthill channel add ... --kind lark) ---
# ANTHILL_LARK_APP_ID=cli_...
# ANTHILL_LARK_APP_SECRET=...
# ANTHILL_LARK_VERIFICATION_TOKEN=...

# --- Telegram (CLI: anthill channel add ... --kind telegram) ---
# ANTHILL_TELEGRAM_BOT_TOKEN=...

# --- Slack (CLI: anthill channel add ... --kind slack) ---
# ANTHILL_SLACK_BOT_TOKEN=xoxb-...

# --- WeCom / 企业微信 (CLI: anthill channel add ... --kind wecom) ---
# ANTHILL_WECOM_CORP_ID=...
# ANTHILL_WECOM_CORP_SECRET=...
# ANTHILL_WECOM_AGENT_ID=1000002

# --- Feature flags (no CLI; env only) ---
# ANTHILL_USE_JUDGE=1                       # enable LLM judge scoring
# ANTHILL_PLUGIN_SHELL_ENABLED=1            # enable shell plugin (caution)
# ANTHILL_PLUGIN_CODE_EXEC_ENABLED=1        # enable code_exec plugin (caution)
# ANTHILL_PLUGIN_WORKSPACE=/home/anthill/workspace
