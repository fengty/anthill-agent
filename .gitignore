# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
env/
.env

# IDE
.vscode/
.idea/
*.swp
*.swo

# Testing
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# Anthill local state
.anthill/
*.db
*.sqlite

# Secrets — never commit. ~/.anthill/secrets.toml lives outside the repo,
# but if anyone copies it in during debugging this catches it.
secrets.toml
**/secrets.toml
*.key
*.pem

# OS
.DS_Store
Thumbs.db
workspace/
